# Copy to .env.local and fill in values
# See VERCEL_ENV_SETUP.md for Vercel environment variables

# ── Live Market Data (server-side only; never exposed to client) ──────────────
# REQUIRED for forex, metals, and stock live prices (primary live source)
FINNHUB_API_KEY=your_finnhub_key
# REQUIRED for Trader Deck economic calendar, treasury rates, market news
FMP_API_KEY=your_fmp_key
# REQUIRED for Trader Deck 10Y yield, CPI, unemployment macro data
FRED_API_KEY=your_fred_key
# Twelve Data REST (primary in briefs / several fallbacks). Venture ~610 req/min; see ENVIRONMENT_VARIABLES_SETUP.md (TWELVE_DATA_API_KEY).
TWELVE_DATA_API_KEY=your_twelve_data_key
# OPTIONAL: symbol for Twelve Data probe in GET /api/ai/health (defaults to EUR/USD). FX pairs should use slash form.
# TWELVE_DATA_HEALTH_SYMBOL=EUR/USD
# OPTIONAL: stock quotes, news sentiment (AI chat market data)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
# OPTIONAL: dedicated metals spot prices (gold, silver) for AI chat
METAL_API_KEY=your_metal_api_key
# OPTIONAL: economic calendar with real events (calendar adapter)
TRADING_ECONOMICS_API_KEY=your_trading_economics_key
# OPTIONAL: breaking market news for AI chat; also powers Surveillance country “Live wire” (NewsAPI top-headlines per ISO2)
NEWS_API_KEY=your_news_api_key
# OPTIONAL: set to 1 on Vercel only if you need logs when NewsAPI/GNews fails (otherwise silent fallback)
# VERBOSE_NEWS=1
# OPTIONAL: set to 1 to log missing FMP/FRED/Finnhub keys in server logs (defaults are quiet in production)
# TRADER_DECK_LOG_MISSING_KEYS=1
# OPTIONAL: US stock + index prices (15-min delayed free tier) – fallback behind Yahoo/Finnhub
# Sign up free at https://polygon.io
POLYGON_API_KEY=your_polygon_key
# OPTIONAL: crypto prices with 24h % change (10,000 free calls/month)
# Sign up free at https://coinmarketcap.com/api
COINMARKETCAP_API_KEY=your_coinmarketcap_key
# OPTIONAL: financial news with per-article sentiment scores (100 free calls/day)
# Sign up free at https://marketaux.com
MARKETAUX_API_KEY=your_marketaux_key
# Optional: cache refresh interval in seconds (default 300 = 5 min). Reduces API rate limit risk.
# MARKET_DATA_REFRESH_INTERVAL=300
# Market Decoder: server cache TTL in seconds (120–900, default 600). Client polls with refresh=1 for live pulls.
# MARKET_DECODER_CACHE_SEC=120
# Market Decoder UI: background refresh interval in ms (min 15000, default 30000).
# REACT_APP_MARKET_DECODER_POLL_MS=30000
#
# Aura FX AI features (chat, reports, Trader Deck, DNA): require PERPLEXITY_API_KEY.
# Optional model overrides:
PERPLEXITY_API_KEY=your_perplexity_api_key
# PERPLEXITY_MODEL=sonar-reasoning-pro
# PERPLEXITY_CHAT_MODEL=sonar-reasoning-pro
# PERPLEXITY_AUTOMATION_MODEL=sonar-reasoning-pro
#
# Aura FX institutional AI briefs (Trader Deck cron): require PERPLEXITY_AUTOMATION_MODEL + PERPLEXITY_API_KEY.
# Cron hits /api/cron/auto-market-briefs (Vercel schedule); runs daily 06:00 UK and weekly Sunday 10:00 UK when due.
# Briefs stored in trader_deck_briefs as brief_kind aura_institutional_daily | aura_institutional_weekly.

# ── Twilio Verify – phone verification ───────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Frontend (CRA) – footer system status (optional) ─────────────────────────
# Green "All systems operational" by default. Set one of these for a red indicator:
# REACT_APP_MAINTENANCE_MODE=true
# REACT_APP_SYSTEM_STATUS=maintenance   # or: down | offline | outage | unavailable
# Optional: ping an endpoint (must return HTTP 200); if disabled, omit or set false
# REACT_APP_FOOTER_HEALTH_CHECK=true
# REACT_APP_FOOTER_HEALTH_URL=https://your-api.example.com/api/health

# ── Web Push (browser/device notifications) ─────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
# Server (Vercel): same pair as below
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# CRA build: public key only (must match VAPID_PUBLIC_KEY)
# REACT_APP_VAPID_PUBLIC_KEY=

# ── Auth & admin (required in production) ─────────────────────────────────────
# Min 16 characters. Required on Vercel/production — unsigned/legacy tokens are rejected when unset.
# JWT_SECRET=your-long-random-secret-here
# Optional: extra super-admin emails (comma or semicolon). Built-in super admins (always): slutherfx@gmail.com; AuraTerminal2002@gmail.com (stored lowercased). Override/env adds more — does not remove built-ins.
# To mirror both operators explicitly on Vercel (optional — fallbacks already apply):
# SUPER_ADMIN_EMAIL=slutherfx@gmail.com,auraterminal2002@gmail.com
# CRA build: same list so Settings/Community super-admin UI matches the server.
# REACT_APP_SUPER_ADMIN_EMAIL=slutherfx@gmail.com,auraterminal2002@gmail.com

# ── Aura Analysis — MetaTrader investor-password sync (server-side) ─────────
# REQUIRED in production for MT4/MT5 Aura Analysis (connect, account, history):
# MT5_WORKER_URL=https://your-mt5-worker.example.com
#   Legacy fallbacks (same meaning): AURA_MT_SYNC_URL, TERMINALSYNC_WORKER_URL, PYTHON_WORKER_URL
# WORKER_SECRET=your-worker-secret
#   Sent on every worker request as header x-worker-secret (never expose to the client).
#   Legacy fallbacks: AURA_MT_SYNC_SECRET, TERMINALSYNC_WORKER_SECRET
#
# REQUIRED in production for encrypted storage of platform credentials (AES-256-GCM):
# PLATFORM_ENCRYPTION_KEY=<long random string, e.g. 32+ bytes as hex or passphrase>
# If unset, the API derives the key from JWT_SECRET (works but couples credential encryption to auth).
# If BOTH are unset, a fixed dev-only default is used — do not deploy production that way.
#
# Auth (required in production): set JWT_SECRET (min 16 chars). See VERCEL_ENV_SETUP.md.
#
# Optional — dev/staging diagnostics only (extra response fields / noisier MT logs). Omit or leave unset in production:
# AURA_ANALYSIS_DIAGNOSTICS=1
#
# ── Surveillance: OpenSky live ADS-B (OAuth2 client credentials; see OpenSky REST API docs) ──
# Create an API client on https://opensky-network.org/ → My OpenSky → Account.
# OPENSKY_CLIENT_ID=your_client_id
# OPENSKY_CLIENT_SECRET=your_client_secret
# Legacy names (same values as client id / secret if you prefer not to rename):
# OPENSKY_USERNAME=your_client_id
# OPENSKY_PASSWORD=your_client_secret
# OPENSKY_TOKEN_REFRESH_MARGIN_SEC=30
# OPENSKY_TOKEN_FETCH_TIMEOUT_MS=12000   # OAuth POST to auth.opensky-network.org (fail fast; avoids multi-minute hangs per box)
# OPENSKY_OAUTH_BACKOFF_SEC=600            # After token failure, skip retrying OAuth this many seconds (default 600 on Vercel, 180 elsewhere)
# OPENSKY_ADAPTER_DISABLED=0
# OPENSKY_MAX_BOXES=3
# OPENSKY_FETCH_TIMEOUT_MS=18000
# OPENSKY_FETCH_ATTEMPTS=2
#
# ── Surveillance: Datalastic live AIS (merchant / tanker traffic; paid plan) ──
# Sign up at https://datalastic.com — credits scale with vessels returned per query.
# Kill switch (any 1/true/yes → zero HTTP to Datalastic): DATALASTIC_ADAPTER_DISABLED, DATALASTIC_AIS_ADAPTER_DISABLED, DATALASTIC_DISABLED
# DATALASTIC_API_KEY=your_key
# Defaults: 1 hub query per ingest unless you raise BOTH caps below (credit safety).
# DATALASTIC_AIS_CALLS_PER_RUN=1
# DATALASTIC_AIS_MAX_CALLS_PER_RUN=1
# DATALASTIC_AIS_TYPE=cargo
# DATALASTIC_AIS_APPLY_TYPE_FILTER=0
# DATALASTIC_AIS_TIMEOUT_MS=22000
# DATALASTIC_AIS_FETCH_ATTEMPTS=1
# DATALASTIC_AIS_ADAPTER_DISABLED=0
# DATALASTIC_ADAPTER_DISABLED=0
# DATALASTIC_DISABLED=0
