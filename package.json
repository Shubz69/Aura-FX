  "scripts": {
    "postinstall": "patch-package || echo \"patch-package skipped\"",
    "start": "react-scripts start",
    "dev": "react-scripts start",
    "local": "vercel dev",
    "icons": "node scripts/generate-aura-icons.js",
    "build:analytics-node": "npx --yes esbuild@0.24.0 src/lib/aura-analysis/analytics.js --bundle --platform=node --format=cjs --outfile=api/aura-analysis/__analytics_node.cjs --log-level=warning",
    "build": "node scripts/generate-aura-icons.js && npm run build:analytics-node && cross-env CI=false GENERATE_SOURCEMAP=false DISABLE_ESLINT_PLUGIN=true node --max-old-space-size=8192 node_modules/react-scripts/scripts/build.js",
    "analyze": "node scripts/generate-aura-icons.js && cross-env CI=false GENERATE_SOURCEMAP=true DISABLE_ESLINT_PLUGIN=true react-scripts build && npx --yes source-map-explorer@2.5.3 \"build/static/js/*.js\" --gzip",
    "test": "react-scripts test",
    "test:security": "node tests/security-rbac.test.js && node tests/rate-limit.test.js && node tests/entitlements-api.test.js && node tests/surveillance-pure.test.js && node tests/csrf-trusted-origins.test.js",
    "test:auth": "node tests/auth-signup-login.test.js",
    "test:ai": "jest tests/ai-chat.test.js --verbose",
    "test:ai:ci": "jest tests/ai-chat.test.js --ci --coverage",
    "eject": "react-scripts eject",
    "test-server": "node test-server.js",
    "test:e2e:audit": "playwright test --config=playwright.audit.config.js",
    "test:e2e:signup": "playwright test --config=playwright.signup.config.js",
    "test:e2e:admin": "playwright test --config=playwright.admin.config.js",
    "test:e2e": "playwright test",
    "test:e2e:operator-intelligence": "playwright test --config=playwright.operator-intelligence.config.js",
    "test:e2e:language": "playwright test --config=playwright.language.config.js",
    "gen:i18n:part8": "node scripts/gen-i18n-part8.mjs",
    "gen:i18n:part9": "node scripts/generate-part9-traderdeck-ui.mjs",
    "build:i18n": "node scripts/build-i18n-locales.mjs",
    "verify:i18n": "node scripts/verify-i18n-locales.mjs"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "three": "^0.183.2",
    "three-globe": "2.45.2"
  },
