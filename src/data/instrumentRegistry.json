{
  "version": "1.1.0",
  "description": "Canonical symbols, aliases, commodity watchlist, calculation anchors, behaviour profiles, MT5 override contract.",
  "mt5BrokerOverrideContract": {
    "description": "Future: merge these fields from MT5 symbol_info into specs via getInstrumentSpec(symbol, { brokerOverrides }).",
    "allowedFields": ["contractSize", "tickSize", "tickValuePerLot", "valuePerPointPerLot", "pointSize", "pipSize", "lotStep", "minLot", "maxLot"]
  },
  "categoryBehaviour": {
    "crypto": {
      "volatilityProfile": "high",
      "sessionBehaviour": "24/7; weekend gap risk; funding/perp basis on derivatives",
      "spreadSensitivity": "wide on thin alts; slippage spikes on volatility",
      "manipulationRisk": "stop-runs and wick spikes on low liquidity events",
      "typicalStructureQuality": "trend spikes and range compression; BTC correlation on alts"
    },
    "forex": {
      "volatilityProfile": "medium (majors lower, exotics higher)",
      "sessionBehaviour": "London/NY liquidity peaks; Asia varies by pair",
      "spreadSensitivity": "widens off-session and into news",
      "manipulationRisk": "moderate around fixes and tier-1 news",
      "typicalStructureQuality": "session-linked trends; mean reversion in ranges"
    },
    "commodities": {
      "volatilityProfile": "high on energy; medium-high on metals; seasonal on ag/softs",
      "sessionBehaviour": "pit/report calendars; gap risk vs equities",
      "spreadSensitivity": "wider on thin CFD roots",
      "manipulationRisk": "stop liquidity engineering common on metals and energy headlines",
      "typicalStructureQuality": "impulse + mean-revert around reports; scale differs from FX pips"
    },
    "indices": {
      "volatilityProfile": "medium-high",
      "sessionBehaviour": "cash hours; gap opens; macro tape",
      "spreadSensitivity": "moderate; wider into cash open",
      "manipulationRisk": "gap and event baskets",
      "typicalStructureQuality": "trend + pullback; points-based rhythm"
    },
    "stocks": {
      "volatilityProfile": "equity-specific",
      "sessionBehaviour": "RTH most liquid",
      "spreadSensitivity": "wider outside RTH",
      "manipulationRisk": "gap on news; halts",
      "typicalStructureQuality": "levels, gaps, earnings drift"
    },
    "etfs": {
      "volatilityProfile": "basket-dependent",
      "sessionBehaviour": "follows underlying cash hours",
      "spreadSensitivity": "generally moderate",
      "manipulationRisk": "rebalance flows",
      "typicalStructureQuality": "tracks index/sector"
    },
    "macro": {
      "volatilityProfile": "instrument-specific",
      "sessionBehaviour": "macro calendars (FOMC, CPI)",
      "spreadSensitivity": "varies",
      "manipulationRisk": "low vs single-name",
      "typicalStructureQuality": "rates trend; VIX mean-revert tendencies"
    },
    "futures": {
      "volatilityProfile": "contract-dependent",
      "sessionBehaviour": "session times; roll weeks",
      "spreadSensitivity": "tick size/value matter",
      "manipulationRisk": "roll and spread dislocations",
      "typicalStructureQuality": "points/ticks; not FX pips unless chart is FX"
    },
    "unknown": {
      "volatilityProfile": "unknown — infer from chart only",
      "sessionBehaviour": "unknown",
      "spreadSensitivity": "unknown",
      "manipulationRisk": "unknown",
      "typicalStructureQuality": "use visible price action only"
    }
  },
  "commoditySubCategoryBehaviour": {
    "metal": {
      "manipulationRisk": "elevated on liquidity sweeps around NY/London",
      "typicalStructureQuality": "clean swings at size; false breaks on news"
    },
    "energy": {
      "manipulationRisk": "inventory and headline stop-runs",
      "typicalStructureQuality": "event volatility; gap risk"
    },
    "agriculture": {
      "manipulationRisk": "report-driven gaps",
      "typicalStructureQuality": "seasonal ranges and trend legs into WASDE-style events"
    },
    "softs": {
      "manipulationRisk": "thin liquidity gaps",
      "typicalStructureQuality": "weather and currency-driven trends"
    },
    "other": {
      "manipulationRisk": "verify with broker symbol specs",
      "typicalStructureQuality": "mixed"
    }
  },
